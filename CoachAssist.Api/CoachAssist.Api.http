### CoachAssist API — Happy path smoke test
### Doorloop in volgorde. Visual Studio 2022+ of VS Code (REST Client extensie) leest dit bestand.
### Named requests (# @name xxx) maken het mogelijk om tokens/IDs automatisch te hergebruiken via {{xxx.response.body.veld}}.

@host = http://localhost:5185

############################################################
# 1. AUTH — drie gebruikers registreren + inloggen
############################################################

### 1a. Registreer Admin
# @name registerAdmin
POST {{host}}/api/auth/register
Content-Type: application/json

{
  "email": "admin@fcbeersel.be",
  "wachtwoord": "Admin123!",
  "voornaam": "Karen",
  "achternaam": "Peeters",
  "rol": "Admin"
}

### 1b. Login Admin → token wordt automatisch opgepakt
# @name loginAdmin
POST {{host}}/api/auth/login
Content-Type: application/json

{
  "email": "admin@fcbeersel.be",
  "wachtwoord": "Admin123!"
}

###
@adminToken = {{loginAdmin.response.body.token}}

### 1c. Registreer Coach
# @name registerCoach
POST {{host}}/api/auth/register
Content-Type: application/json

{
  "email": "thomas@fcbeersel.be",
  "wachtwoord": "Coach123!",
  "voornaam": "Thomas",
  "achternaam": "Verhaert",
  "rol": "Coach"
}

### 1d. Login Coach
# @name loginCoach
POST {{host}}/api/auth/login
Content-Type: application/json

{
  "email": "thomas@fcbeersel.be",
  "wachtwoord": "Coach123!"
}

###
@coachToken = {{loginCoach.response.body.token}}
@coachId = {{loginCoach.response.body.gebruiker.gebruikerId}}

### 1e. Registreer Speler (gebruiker met rol Speler — voor onboarding test in sectie 7)
# @name registerSpeler
POST {{host}}/api/auth/register
Content-Type: application/json

{
  "email": "mathis@fcbeersel.be",
  "wachtwoord": "Speler123!",
  "voornaam": "Mathis",
  "achternaam": "De Wolf",
  "rol": "Speler"
}

### 1f. Login Speler
# @name loginSpeler
POST {{host}}/api/auth/login
Content-Type: application/json

{
  "email": "mathis@fcbeersel.be",
  "wachtwoord": "Speler123!"
}

###
@spelerToken = {{loginSpeler.response.body.token}}

### 1g. /me als verificatie van Coach-token
GET {{host}}/api/auth/me
Authorization: Bearer {{coachToken}}


############################################################
# 2. CLUB-STRUCTUUR — Admin maakt Club, Terrein, Team aan
############################################################

### 2a. Admin maakt Club
# @name maakClub
POST {{host}}/api/clubs
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "naam": "FC Beersel",
  "stad": "Beersel"
}

###
@clubId = {{maakClub.response.body.clubId}}

### 2b. Admin maakt Terrein
# @name maakTerrein
POST {{host}}/api/terreinen
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "naam": "Sportpark Beersel",
  "adres": "Beerselstraat 1",
  "clubId": {{clubId}}
}

###
@terreinId = {{maakTerrein.response.body.terreinId}}

### 2c. Admin maakt Team (gekoppeld aan Coach)
# @name maakTeam
POST {{host}}/api/teams
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "naam": "U17b BEERSEL",
  "seizoen": "2025-2026",
  "clubId": {{clubId}},
  "coachId": {{coachId}}
}

###
@teamId = {{maakTeam.response.body.teamId}}

### 2d. Iedereen kan club zoeken (geen auth) — voor onboarding
GET {{host}}/api/clubs?zoek=beersel

### 2e. Teams van een club
GET {{host}}/api/clubs/{{clubId}}/teams


############################################################
# 3. SPELERS — Coach voegt spelers toe aan eigen team
############################################################

### 3a. Coach voegt Mathis toe (handmatig, zonder gekoppelde Gebruiker)
# @name maakSpeler1
POST {{host}}/api/spelers
Authorization: Bearer {{coachToken}}
Content-Type: application/json

{
  "voornaam": "Mathis",
  "achternaam": "De Wolf",
  "rugnummer": 9,
  "vastePositie": "Aanvaller",
  "teamId": {{teamId}}
}

###
@speler1Id = {{maakSpeler1.response.body.spelerId}}

### 3b. Coach voegt Luca toe
# @name maakSpeler2
POST {{host}}/api/spelers
Authorization: Bearer {{coachToken}}
Content-Type: application/json

{
  "voornaam": "Luca",
  "achternaam": "Peeters",
  "rugnummer": 4,
  "vastePositie": "Middenvelder",
  "teamId": {{teamId}}
}

###
@speler2Id = {{maakSpeler2.response.body.spelerId}}

### 3c. Coach voegt Noah toe (keeper)
# @name maakSpeler3
POST {{host}}/api/spelers
Authorization: Bearer {{coachToken}}
Content-Type: application/json

{
  "voornaam": "Noah",
  "achternaam": "Vermeersch",
  "rugnummer": 1,
  "vastePositie": "Keeper",
  "teamId": {{teamId}}
}

###
@speler3Id = {{maakSpeler3.response.body.spelerId}}

### 3d. Team-detail bekijken (inclusief spelerslijst)
GET {{host}}/api/teams/{{teamId}}
Authorization: Bearer {{coachToken}}


############################################################
# 4. WEDSTRIJD + OPSTELLING + STATISTIEKEN
############################################################

### 4a. Coach maakt Wedstrijd
# @name maakWedstrijd
POST {{host}}/api/wedstrijden
Authorization: Bearer {{coachToken}}
Content-Type: application/json

{
  "datum": "2026-06-15T00:00:00",
  "startTijd": "14:00:00",
  "tegenstander": "KV Halle",
  "teamId": {{teamId}},
  "terreinId": {{terreinId}}
}

###
@wedstrijdId = {{maakWedstrijd.response.body.wedstrijdId}}

### 4b. Coach maakt Opstelling (4-3-3, 3 spelers als voorbeeld)
# @name maakOpstelling
POST {{host}}/api/opstellingen
Authorization: Bearer {{coachToken}}
Content-Type: application/json

{
  "wedstrijdId": {{wedstrijdId}},
  "formatie": "4-3-3",
  "spelers": [
    { "spelerId": {{speler3Id}}, "positieNaam": "Keeper", "veldPositieX": 50, "veldPositieY": 5 },
    { "spelerId": {{speler2Id}}, "positieNaam": "CentraleMiddenvelder", "veldPositieX": 50, "veldPositieY": 50 },
    { "spelerId": {{speler1Id}}, "positieNaam": "Spits", "veldPositieX": 50, "veldPositieY": 90 }
  ]
}

### 4c. Opstelling ophalen
GET {{host}}/api/opstellingen/{{wedstrijdId}}
Authorization: Bearer {{coachToken}}

### 4d. Coach voert statistieken in (bulk, na de match)
POST {{host}}/api/statistieken/wedstrijd/{{wedstrijdId}}
Authorization: Bearer {{coachToken}}
Content-Type: application/json

{
  "thuisScore": 3,
  "uitScore": 1,
  "statistieken": [
    { "spelerId": {{speler1Id}}, "goals": 2, "assists": 0, "geleKaarten": 0, "rodeKaarten": 0, "gespeeldeMinuten": 90 },
    { "spelerId": {{speler2Id}}, "goals": 1, "assists": 1, "geleKaarten": 1, "rodeKaarten": 0, "gespeeldeMinuten": 90 },
    { "spelerId": {{speler3Id}}, "goals": 0, "assists": 0, "geleKaarten": 0, "rodeKaarten": 0, "gespeeldeMinuten": 90 }
  ]
}

### 4e. Stats van de wedstrijd ophalen
GET {{host}}/api/statistieken/wedstrijd/{{wedstrijdId}}
Authorization: Bearer {{coachToken}}

### 4f. Seizoenoverzicht van het team (topscorers)
GET {{host}}/api/teams/{{teamId}}/seizoen
Authorization: Bearer {{coachToken}}

### 4g. Stats van één speler (Mathis)
GET {{host}}/api/spelers/{{speler1Id}}/seizoen
Authorization: Bearer {{coachToken}}


############################################################
# 5. TRAININGEN + AANWEZIGHEID
############################################################

### 5a. Coach maakt een training (volgende dinsdag 19:00-20:30)
# @name maakTraining
POST {{host}}/api/trainingen
Authorization: Bearer {{coachToken}}
Content-Type: application/json

{
  "datum": "2026-06-09T00:00:00",
  "startTijd": "19:00:00",
  "eindTijd": "20:30:00",
  "teamId": {{teamId}},
  "terreinId": {{terreinId}},
  "opmerking": "Eerste training na de vakantie"
}

###
@trainingId = {{maakTraining.response.body.trainingId}}

### 5b. Coach maakt een reeks (elke dinsdag van juni tot juli)
POST {{host}}/api/trainingen/reeks
Authorization: Bearer {{coachToken}}
Content-Type: application/json

{
  "dagVanDeWeek": "Tuesday",
  "startTijd": "19:00:00",
  "eindTijd": "20:30:00",
  "teamId": {{teamId}},
  "terreinId": {{terreinId}},
  "eersteDatum": "2026-06-16T00:00:00",
  "laatsteDatum": "2026-07-21T00:00:00"
}

### 5c. Conflict-test: zelfde dag/tijd/terrein → moet 409 geven
POST {{host}}/api/trainingen
Authorization: Bearer {{coachToken}}
Content-Type: application/json

{
  "datum": "2026-06-09T00:00:00",
  "startTijd": "19:30:00",
  "eindTijd": "20:00:00",
  "teamId": {{teamId}},
  "terreinId": {{terreinId}}
}

### 5d. Aanwezigheidslijst van de training (coach)
GET {{host}}/api/aanwezigheid/training/{{trainingId}}
Authorization: Bearer {{coachToken}}


############################################################
# 6. ALL TRAININGEN/WEDSTRIJDEN ZIEN
############################################################

### 6a. Wedstrijden van het team
GET {{host}}/api/wedstrijden?teamId={{teamId}}
Authorization: Bearer {{coachToken}}

### 6b. Trainingen van het team
GET {{host}}/api/trainingen?teamId={{teamId}}
Authorization: Bearer {{coachToken}}


############################################################
# 7. ONBOARDING-FLOW (Aanvragen)
# Demonstreert de aanvragen-endpoints. LET OP: het maken van een
# TeamAanvraag vereist dat er al een Speler-record bestaat dat
# gekoppeld is aan de Gebruiker (via Speler.GebruikerId).
# Voor de huidige MVP moet die koppeling handmatig gebeuren — dit
# is een bekende rough edge in de architectuur (zie Slice C plan).
############################################################

### 7a. Speler vraagt aan bij FC Beersel
# @name clubAanvraag
POST {{host}}/api/aanvragen/club
Authorization: Bearer {{spelerToken}}
Content-Type: application/json

{
  "clubId": {{clubId}}
}

###
@clubAanvraagId = {{clubAanvraag.response.body.aanvraagId}}

### 7b. Admin ziet openstaande aanvragen
GET {{host}}/api/aanvragen/club?clubId={{clubId}}
Authorization: Bearer {{adminToken}}

### 7c. Admin keurt aanvraag goed
PUT {{host}}/api/aanvragen/club/{{clubAanvraagId}}/goedkeuren
Authorization: Bearer {{adminToken}}

### 7d. (Verwachte gap) Speler probeert TeamAanvraag → faalt met "Geen spelerprofiel gevonden"
### omdat er nog geen Speler-record met spelerToken.GebruikerId bestaat.
POST {{host}}/api/aanvragen/team
Authorization: Bearer {{spelerToken}}
Content-Type: application/json

{
  "teamId": {{teamId}}
}


############################################################
# 8. NEGATIVE TESTS — veiligheid + foutafhandeling
############################################################

### 8a. /me zonder token → 401
GET {{host}}/api/auth/me

### 8b. Coach probeert Club aan te maken → 403 Forbidden (AdminOnly)
POST {{host}}/api/clubs
Authorization: Bearer {{coachToken}}
Content-Type: application/json

{
  "naam": "FC Brussel",
  "stad": "Brussel"
}

### 8c. Login met fout wachtwoord → 401
POST {{host}}/api/auth/login
Content-Type: application/json

{
  "email": "thomas@fcbeersel.be",
  "wachtwoord": "FoutWachtwoord!"
}

### 8d. Dubbele club-naam → 409 Conflict
POST {{host}}/api/clubs
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "naam": "FC Beersel",
  "stad": "Beersel"
}
