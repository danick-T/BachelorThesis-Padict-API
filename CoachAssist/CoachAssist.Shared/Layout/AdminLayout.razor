@inherits LayoutComponentBase
@inject ICoachAssistApiClient ApiClient
@inject CoachAssistDataContext DataContext

<div class="app-shell">
    <aside class="app-sidebar">
        <div class="app-sidebar-brand">
            <div class="brand-logo">CA</div>
            <div>
                <div class="app-sidebar-brand-text">CoachAssist</div>
                <div class="app-sidebar-brand-sub">@ClubNaam</div>
            </div>
        </div>

        <nav class="app-sidebar-nav">
            <NavLink class="app-nav-item" href="/admin" Match="NavLinkMatch.All">
                <span class="app-nav-icon">D</span> Dashboard
            </NavLink>
            <NavLink class="app-nav-item" href="/admin/aanvragen">
                <span class="app-nav-icon">A</span> Aanvragen
                @if (OpenAanvragen > 0)
                {
                    <span class="app-nav-badge">@OpenAanvragen</span>
                }
            </NavLink>
            <NavLink class="app-nav-item" href="/admin/club">
                <span class="app-nav-icon">C</span> Club
            </NavLink>
            <NavLink class="app-nav-item" href="/admin/terreinen">
                <span class="app-nav-icon">T</span> Terreinen
            </NavLink>
            <NavLink class="app-nav-item" href="/admin/meldingen">
                <span class="app-nav-icon">!</span> Meldingen
            </NavLink>
            <NavLink class="app-nav-item" href="/admin/profiel">
                <span class="app-nav-icon">P</span> Profiel
            </NavLink>
        </nav>

        <div class="app-sidebar-user">
            <div class="avatar avatar-sm" style="background:#374151;">@Initialen</div>
            <div>
                <div class="app-sidebar-user-name">@Naam</div>
                <div class="app-sidebar-user-role">Administrator</div>
            </div>
        </div>
    </aside>

    <div class="app-main">
        @Body
    </div>

    <nav class="bottom-tabs">
        <NavLink href="/admin" Match="NavLinkMatch.All"><span class="tab-icon">D</span>Dashboard</NavLink>
        <NavLink href="/admin/aanvragen"><span class="tab-icon">A</span>Aanvragen</NavLink>
        <NavLink href="/admin/club"><span class="tab-icon">C</span>Club</NavLink>
        <NavLink href="/admin/profiel"><span class="tab-icon">P</span>Profiel</NavLink>
    </nav>

    <CoachAssist.Shared.Components.ToastHost />
</div>

@code {
    private string ClubNaam = "Club";
    private string Naam = "Administrator";
    private string Initialen = "A";
    private int OpenAanvragen;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var gebruiker = ApiClient.AuthSession.Gebruiker ?? await ApiClient.GetCurrentUserAsync();
            if (gebruiker is not null)
            {
                Naam = $"{gebruiker.Voornaam} {gebruiker.Achternaam}".Trim();
                Initialen = BuildInitialen(Naam);
            }

            var club = await DataContext.GetEersteClubAsync();
            if (club is null)
            {
                return;
            }

            ClubNaam = club.Naam;
            OpenAanvragen = (await DataContext.GetOpenClubAanvragenAsync(club.ClubId)).Count;
        }
        catch
        {
            // De pagina zelf toont de concrete laadfout.
        }
    }

    private static string BuildInitialen(string naam)
    {
        var delen = naam.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return string.Concat(delen.Take(2).Select(d => char.ToUpperInvariant(d[0])));
    }
}
