@page "/coach"
@layout CoachAssist.Shared.Layout.CoachLayout
@using CoachAssist.Core.DTOs.Statistiek
@using CoachAssist.Core.DTOs.Training
@using CoachAssist.Core.DTOs.Wedstrijd
@using CoachAssist.Core.Enums
@inject CoachAssistDataContext DataContext

<PageTitle>Coach dashboard - CoachAssist</PageTitle>

<div class="app-topbar">
    <div>
        <h1>Goedemorgen, @CoachNaam</h1>
        <div class="app-topbar-sub">@(TeamNaam ?? "Mijn team") · @(Seizoen ?? "Seizoen")</div>
    </div>
    <div class="app-topbar-actions">
        <button class="icon-btn">🔔<span class="dot"></span></button>
        <a class="btn-primary desktop-only" href="/coach/wedstrijd/nieuw">+ Nieuwe activiteit</a>
    </div>
</div>

<div class="app-content">
    @if (IsLoading)
    {
        <div class="card text-sm text-muted">Dashboard wordt geladen...</div>
    }
    else if (!string.IsNullOrWhiteSpace(ErrorMessage))
    {
        <div class="card text-sm" style="background:#FEF2F2; border-color:#FECACA; color:#991B1B;">@ErrorMessage</div>
    }
    else
    {
        <div class="stats-row desktop-only">
            <div class="stat-tile">
                <span class="stat-tile-pill">Gespeeld</span>
                <div class="stat-tile-value">@Gespeeld.Count</div>
            </div>
            <div class="stat-tile">
                <span class="stat-tile-pill">Gewonnen</span>
                <div class="stat-tile-value">@Gewonnen</div>
            </div>
            <div class="stat-tile">
                <span class="stat-tile-pill warn">Gelijk</span>
                <div class="stat-tile-value">@Gelijk</div>
            </div>
            <div class="stat-tile">
                <span class="stat-tile-pill danger">Verloren</span>
                <div class="stat-tile-value">@Verloren</div>
            </div>
        </div>

        <div class="row-2col mt-16">
            <div>
                <h2 class="section-label">Volgende wedstrijd</h2>
                @if (VolgendeWedstrijd is null)
                {
                    <div class="card text-sm text-muted">Er staat nog geen volgende wedstrijd ingepland.</div>
                }
                else
                {
                    <div class="card" style="background: var(--primary); color:#fff; border:none;">
                        <div class="flex-between" style="margin-bottom: 14px;">
                            <span class="badge badge-gepland">@VolgendeWedstrijd.Status</span>
                            <span class="text-sm" style="opacity:.8;">@VolgendeWedstrijd.Datum.ToString("dd/MM") · @VolgendeWedstrijd.StartTijd.ToString(@"hh\:mm")</span>
                        </div>
                        <div class="flex-between" style="gap: 16px;">
                            <div style="flex:1; text-align:center;">
                                <div class="text-xs" style="opacity:.7;">THUIS</div>
                                <div class="fw-600" style="font-size:18px;">@TeamNaam</div>
                            </div>
                            <div style="opacity:.6;">VS</div>
                            <div style="flex:1; text-align:center;">
                                <div class="text-xs" style="opacity:.7;">UIT</div>
                                <div class="fw-600" style="font-size:18px;">@VolgendeWedstrijd.Tegenstander</div>
                            </div>
                        </div>
                        <div class="flex-between mt-16" style="border-top: 1px solid rgba(255,255,255,0.12); padding-top: 12px;">
                            <span class="text-sm" style="opacity:.85;">Terrein @VolgendeWedstrijd.TerreinId</span>
                            <a href="/coach/opstelling" style="color: var(--highlight); font-weight:600; font-size: 13px;">Details →</a>
                        </div>
                    </div>
                }

                <h2 class="section-label mt-24">Laatste resultaten</h2>
                <div class="card" style="padding: 0;">
                    @foreach (var r in Gespeeld.OrderByDescending(w => w.Datum).Take(4))
                    {
                        <div class="flex-between" style="padding: 12px 16px; border-bottom: 1px solid var(--border);">
                            <div class="flex gap-12" style="align-items:center;">
                                <span class="badge @BadgeClass(r)" style="width:28px; height:28px; padding:0; justify-content:center; border-radius:50%;">@ResultaatLetter(r)</span>
                                <div>
                                    <div class="fw-600">@TeamNaam vs @r.Tegenstander</div>
                                    <div class="text-xs text-muted">@r.Datum.ToString("dd/MM/yyyy") · Competitie</div>
                                </div>
                            </div>
                            <div class="fw-600">@Score(r)</div>
                        </div>
                    }
                    @if (!Gespeeld.Any())
                    {
                        <div class="text-sm text-muted" style="padding: 20px;">Nog geen gespeelde wedstrijden.</div>
                    }
                </div>
            </div>

            <div>
                <h2 class="section-label">Volgende training</h2>
                @if (VolgendeTraining is null)
                {
                    <div class="card text-sm text-muted">Er staat nog geen volgende training ingepland.</div>
                }
                else
                {
                    <div class="card">
                        <div class="flex gap-12" style="align-items:center;">
                            <div class="avatar" style="background:#DCFCE7; color: var(--accent);">T</div>
                            <div>
                                <div class="fw-600">@VolgendeTraining.Datum.ToString("dd/MM/yyyy")</div>
                                <div class="text-sm text-muted">@VolgendeTraining.StartTijd.ToString(@"hh\:mm")-@VolgendeTraining.EindTijd.ToString(@"hh\:mm") · @VolgendeTraining.TerreinNaam</div>
                            </div>
                        </div>
                    </div>
                }

                <h2 class="section-label mt-24 desktop-only">Recente activiteit</h2>
                <div class="card desktop-only" style="padding: 0;">
                    @foreach (var item in Activiteiten)
                    {
                        <div class="flex gap-12" style="padding: 12px 16px; border-bottom: 1px solid var(--border); align-items:center;">
                            <div style="font-size:18px;">@item.Icon</div>
                            <div style="flex:1;">
                                <div class="text-sm fw-600">@item.Tekst</div>
                                <div class="text-xs text-muted">@item.Sub</div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    }
</div>

@code {
    record ActiviteitItem(string Icon, string Tekst, string Sub);

    private bool IsLoading = true;
    private string? ErrorMessage;
    private string CoachNaam = "coach";
    private string? TeamNaam;
    private string? Seizoen;
    private TrainingResponse? VolgendeTraining;
    private WedstrijdResponse? VolgendeWedstrijd;
    private readonly List<WedstrijdResponse> Wedstrijden = new();
    private readonly List<ActiviteitItem> Activiteiten = new();

    private List<WedstrijdResponse> Gespeeld => Wedstrijden
        .Where(w => w.Status == WedstrijdStatus.Gespeeld && w.ThuisScore.HasValue && w.UitScore.HasValue)
        .ToList();

    private int Gewonnen => Gespeeld.Count(w => w.ThuisScore > w.UitScore);
    private int Gelijk => Gespeeld.Count(w => w.ThuisScore == w.UitScore);
    private int Verloren => Gespeeld.Count(w => w.ThuisScore < w.UitScore);

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var team = await DataContext.GetTeamVoorCoachAsync();
            if (team is null)
            {
                ErrorMessage = "Er kon geen team gevonden worden voor deze coach.";
                return;
            }

            CoachNaam = team.CoachNaam?.Split(' ', StringSplitOptions.RemoveEmptyEntries).FirstOrDefault() ?? "coach";
            TeamNaam = team.Naam;
            Seizoen = team.Seizoen;

            var trainingen = await DataContext.GetTrainingenVoorTeamAsync(team.TeamId);
            VolgendeTraining = trainingen
                .Where(t => t.Datum.Date >= DateTime.Today && t.Status == TrainingStatus.Gepland)
                .OrderBy(t => t.Datum)
                .ThenBy(t => t.StartTijd)
                .FirstOrDefault();

            Wedstrijden.AddRange(await DataContext.GetWedstrijdenVoorTeamAsync(team.TeamId));
            VolgendeWedstrijd = Wedstrijden
                .Where(w => w.Datum.Date >= DateTime.Today && w.Status == WedstrijdStatus.Gepland)
                .OrderBy(w => w.Datum)
                .ThenBy(w => w.StartTijd)
                .FirstOrDefault();

            var openAanvragen = await DataContext.GetOpenTeamAanvragenAsync(team.TeamId);
            if (openAanvragen.Count > 0)
            {
                Activiteiten.Add(new ActiviteitItem("!", $"{openAanvragen.Count} nieuwe spelersverzoeken", team.Naam));
            }

            if (Gespeeld.OrderByDescending(w => w.Datum).FirstOrDefault() is { } laatste)
            {
                Activiteiten.Add(new ActiviteitItem("S", $"Stats beschikbaar voor {laatste.Tegenstander}", Score(laatste)));
            }

            if (VolgendeTraining is not null)
            {
                Activiteiten.Add(new ActiviteitItem("T", "Volgende training ingepland", VolgendeTraining.Datum.ToString("dd/MM/yyyy")));
            }
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.Message;
        }
        finally
        {
            IsLoading = false;
        }
    }

    private static string Score(WedstrijdResponse wedstrijd) =>
        wedstrijd.ThuisScore.HasValue && wedstrijd.UitScore.HasValue
            ? $"{wedstrijd.ThuisScore}-{wedstrijd.UitScore}"
            : "-";

    private static string ResultaatLetter(WedstrijdResponse wedstrijd)
    {
        if (wedstrijd.ThuisScore > wedstrijd.UitScore) return "W";
        if (wedstrijd.ThuisScore == wedstrijd.UitScore) return "G";
        return "V";
    }

    private static string BadgeClass(WedstrijdResponse wedstrijd) => ResultaatLetter(wedstrijd) switch
    {
        "W" => "badge-gespeeld",
        "G" => "badge-afwacht",
        _ => "badge-geweigerd"
    };
}
