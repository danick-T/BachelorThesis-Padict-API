@page "/admin/aanvragen"
@layout CoachAssist.Shared.Layout.AdminLayout
@using CoachAssist.Core.DTOs.Aanvraag
@using CoachAssist.Core.Enums
@inject Toast Toast
@inject CoachAssistDataContext DataContext
@inject ICoachAssistApiClient Api

<PageTitle>Aanvragen - CoachAssist</PageTitle>

<div class="app-topbar">
    <div>
        <h1>Aanvragen</h1>
        <div class="app-topbar-sub">@Items.Count(i => i.Status == AanvraagStatus.InAfwachting) openstaande aanvragen voor lidmaatschap</div>
    </div>
    <div class="app-topbar-actions">
        <button class="btn-secondary" disabled="@(IsProcessing || !Items.Any(i => i.Status == AanvraagStatus.InAfwachting))" @onclick="AllesWeigeren">Alles weigeren</button>
        <button class="btn-primary" disabled="@(IsProcessing || Geselecteerd.Count == 0)" @onclick="GeselecteerdeGoedkeuren">Geselecteerde goedkeuren (@Geselecteerd.Count)</button>
    </div>
</div>

<div class="app-content">
    @if (IsLoading)
    {
        <div class="card text-sm text-muted">Aanvragen worden geladen...</div>
    }
    else if (!string.IsNullOrWhiteSpace(ErrorMessage))
    {
        <div class="card text-sm" style="background:#FEF2F2; border-color:#FECACA; color:#991B1B;">@ErrorMessage</div>
    }
    else
    {
        <div style="display:grid; grid-template-columns: 2fr 1fr; gap: 24px;" class="aanvragen-grid">
            <div>
                <div class="chips">
                    <button class="chip @(Tab == AanvraagStatus.InAfwachting ? "active" : "")" @onclick="() => Tab = AanvraagStatus.InAfwachting">In afwachting <span class="chip-count">@Items.Count(i => i.Status == AanvraagStatus.InAfwachting)</span></button>
                    <button class="chip @(Tab == AanvraagStatus.Goedgekeurd ? "active" : "")" @onclick="() => Tab = AanvraagStatus.Goedgekeurd">Goedgekeurd <span class="chip-count">@Items.Count(i => i.Status == AanvraagStatus.Goedgekeurd)</span></button>
                    <button class="chip @(Tab == AanvraagStatus.Geweigerd ? "active" : "")" @onclick="() => Tab = AanvraagStatus.Geweigerd">Geweigerd <span class="chip-count">@Items.Count(i => i.Status == AanvraagStatus.Geweigerd)</span></button>
                </div>

                <div class="flex gap-12 mt-12">
                    <input class="search-input" placeholder="Zoek op naam of e-mail..." @bind="Zoek" @bind:event="oninput" style="flex:1;" />
                </div>

                <div class="card mt-16" style="padding: 0;">
                    <div class="flex desktop-only" style="padding: 12px 16px; font-size: 11px; color: var(--text-muted); text-transform: uppercase; border-bottom: 1px solid var(--border);">
                        <div style="width:24px;"></div>
                        <div style="flex:2;">Naam</div>
                        <div style="flex:2;">Club</div>
                        <div style="flex:1;">Ontvangen</div>
                        <div style="width:80px;">Acties</div>
                    </div>
                    @foreach (var a in Gefilterd)
                    {
                        <div class="flex aanvraag-row @(Actief == a ? "row-selected" : "")" style="padding:12px 16px; border-bottom:1px solid var(--border); align-items:center; cursor:pointer;" @onclick="() => Actief = a">
                            <div style="width: 24px;"><input type="checkbox" checked="@Geselecteerd.Contains(a)" @onclick:stopPropagation="true" @onchange="() => Toggle(a)" /></div>
                            <div style="flex:2;" class="flex gap-8" >
                                <div class="avatar avatar-sm">@Initialen(a.GebruikerNaam)</div>
                                <div>
                                    <div class="text-sm fw-600">@a.GebruikerNaam</div>
                                    <div class="text-xs text-muted">@a.Email</div>
                                </div>
                            </div>
                            <div style="flex:2;" class="text-sm">@a.ClubNaam</div>
                            <div style="flex:1;" class="text-sm text-muted">@Datum(a.DatumAanvraag)</div>
                            <div class="flex gap-4" style="width:80px;">
                                <button class="btn-icon-approve" disabled="@IsProcessing" @onclick:stopPropagation="true" @onclick="() => Goedkeur(a)">✓</button>
                                <button class="btn-icon-reject" disabled="@IsProcessing" @onclick:stopPropagation="true" @onclick="() => Weiger(a)">x</button>
                            </div>
                        </div>
                    }
                    @if (!Gefilterd.Any())
                    {
                        <div class="text-sm text-muted" style="text-align:center; padding: 30px;">Geen aanvragen gevonden.</div>
                    }
                </div>
                <div class="text-xs text-muted mt-8">Toont @Gefilterd.Count() van @Items.Count(i => i.Status == Tab) resultaten</div>
            </div>

            <div>
                @if (Actief != null)
                {
                    <div class="card" style="position: sticky; top: 16px;">
                        <div class="flex gap-12" style="align-items:center;">
                            <div class="avatar">@Initialen(Actief.GebruikerNaam)</div>
                            <div>
                                <div class="fw-600">@Actief.GebruikerNaam</div>
                                <div class="text-xs text-muted">@Actief.Email</div>
                            </div>
                        </div>
                        <div class="mt-8"><span class="badge badge-afwacht">@Actief.Status</span></div>

                        <div class="text-xs text-muted fw-600 mt-16" style="text-transform:uppercase;">Aanvraag</div>
                        <div class="flex-between text-sm" style="padding: 6px 0;"><span class="text-muted">Club</span><span class="fw-600">@Actief.ClubNaam</span></div>
                        <div class="flex-between text-sm" style="padding: 6px 0;"><span class="text-muted">Aangevraagd op</span><span class="fw-600">@Datum(Actief.DatumAanvraag)</span></div>

                        @if (Actief.Status == AanvraagStatus.InAfwachting)
                        {
                            <div class="flex gap-8 mt-16">
                                <button class="btn-danger" style="flex:1; height: 40px;" disabled="@IsProcessing" @onclick="() => Weiger(Actief)">Weigeren</button>
                                <button class="btn-primary" style="flex:1; height: 40px;" disabled="@IsProcessing" @onclick="() => Goedkeur(Actief)">Goedkeuren</button>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="card" style="text-align:center; padding: 30px;">
                        <div class="text-xs text-muted">Klik op een aanvraag om de details te bekijken</div>
                    </div>
                }
            </div>
        </div>
    }
</div>

<style>
    .aanvragen-grid { grid-template-columns: 2fr 1fr; }
    @@media (max-width: 1100px) { .aanvragen-grid { grid-template-columns: 1fr; } }
    .row-selected { background: #F0FDF4; }
    .aanvraag-row:hover { background: #F9FAFB; }
</style>

@code {
    private AanvraagStatus Tab = AanvraagStatus.InAfwachting;
    private bool IsLoading = true;
    private bool IsProcessing;
    private string? ErrorMessage;
    private string Zoek = "";
    private ClubAanvraagResponse? Actief;
    private HashSet<ClubAanvraagResponse> Geselecteerd = new();
    private List<ClubAanvraagResponse> Items = new();

    private IEnumerable<ClubAanvraagResponse> Gefilterd
    {
        get
        {
            var q = Items.Where(i => i.Status == Tab);
            if (!string.IsNullOrWhiteSpace(Zoek))
            {
                q = q.Where(i => i.GebruikerNaam.Contains(Zoek, StringComparison.OrdinalIgnoreCase)
                              || i.Email.Contains(Zoek, StringComparison.OrdinalIgnoreCase));
            }

            return q;
        }
    }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var club = await DataContext.GetEersteClubAsync();
            if (club is null)
            {
                ErrorMessage = "Er kon geen club gevonden worden.";
                return;
            }

            Items = await DataContext.GetOpenClubAanvragenAsync(club.ClubId);
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.Message;
        }
        finally
        {
            IsLoading = false;
        }
    }

    private void Toggle(ClubAanvraagResponse aanvraag)
    {
        if (!Geselecteerd.Add(aanvraag)) Geselecteerd.Remove(aanvraag);
    }

    private async Task Goedkeur(ClubAanvraagResponse aanvraag) =>
        await Verwerk(aanvraag, "goedkeuren", AanvraagStatus.Goedgekeurd, "goedgekeurd", "success");

    private async Task Weiger(ClubAanvraagResponse aanvraag) =>
        await Verwerk(aanvraag, "weigeren", AanvraagStatus.Geweigerd, "geweigerd", "error");

    private async Task GeselecteerdeGoedkeuren()
    {
        foreach (var aanvraag in Geselecteerd.ToList())
        {
            await Goedkeur(aanvraag);
        }
    }

    private async Task AllesWeigeren()
    {
        foreach (var aanvraag in Items.Where(i => i.Status == AanvraagStatus.InAfwachting).ToList())
        {
            await Weiger(aanvraag);
        }
    }

    private async Task Verwerk(
        ClubAanvraagResponse aanvraag,
        string actie,
        AanvraagStatus nieuweStatus,
        string toastTekst,
        string toastType)
    {
        IsProcessing = true;
        ErrorMessage = null;

        try
        {
            using var request = new HttpRequestMessage(HttpMethod.Put, $"api/aanvragen/club/{aanvraag.AanvraagId}/{actie}");
            using var response = await Api.SendAuthorizedAsync(request);
            if (!response.IsSuccessStatusCode)
            {
                ErrorMessage = "De aanvraag kon niet verwerkt worden.";
                return;
            }

            aanvraag.Status = nieuweStatus;
            Geselecteerd.Remove(aanvraag);
            if (Actief == aanvraag) Actief = null;
            await Toast.Show($"{aanvraag.GebruikerNaam} {toastTekst}", toastType);
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.Message;
        }
        finally
        {
            IsProcessing = false;
        }
    }

    private static string Initialen(string naam)
    {
        var delen = naam.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return string.Concat(delen.Take(2).Select(d => d[0])).ToUpperInvariant();
    }

    private static string Datum(DateTime? datum) => datum?.ToString("dd/MM/yyyy") ?? "";
}
