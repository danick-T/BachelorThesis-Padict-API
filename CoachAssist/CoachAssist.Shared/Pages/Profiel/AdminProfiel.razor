@page "/admin/profiel"
@layout CoachAssist.Shared.Layout.AdminLayout
@inject NavigationManager Nav
@inject ICoachAssistApiClient ApiClient
@inject CoachAssistDataContext DataContext

<PageTitle>Profiel - CoachAssist</PageTitle>

<div class="app-topbar">
    <h1>Mijn profiel</h1>
    <div class="app-topbar-actions">
        <a class="btn-secondary" href="/instellingen">Instellingen</a>
    </div>
</div>

<div class="app-content" style="max-width: 640px; margin: 0 auto;">
    @if (Laden)
    {
        <div class="card text-sm text-muted">Profiel wordt geladen...</div>
    }
    else if (!string.IsNullOrWhiteSpace(Fout))
    {
        <div class="card text-sm" style="background:#FEF2F2; border-color:#FECACA; color:#991B1B;">@Fout</div>
    }
    else
    {
        <div class="card" style="background: var(--primary); color: #fff; border:none; text-align:center; padding: 28px;">
            <div class="avatar avatar-lg" style="background: var(--highlight); color: var(--primary); margin: 0 auto;">@Initialen</div>
            <div class="fw-600 mt-12" style="font-size: 18px;">@Naam</div>
            <div class="text-sm" style="opacity:.75;">Administrator - @ClubNaam</div>
        </div>

        <div class="text-xs text-muted mt-16" style="text-transform:uppercase; font-weight:600;">Account</div>
        <div class="card mt-8" style="padding:0;">
            <div class="flex-between" style="padding:14px; border-bottom: 1px solid var(--border);"><span class="text-muted text-sm">Club</span><span class="fw-600 text-sm">@ClubNaam</span></div>
            <div class="flex-between" style="padding:14px; border-bottom: 1px solid var(--border);"><span class="text-muted text-sm">E-mail</span><span class="fw-600 text-sm">@Email</span></div>
            <div class="flex-between" style="padding:14px;"><span class="text-muted text-sm">Rol</span><span class="fw-600 text-sm">Administrator</span></div>
        </div>

        <button class="btn-secondary mt-16" style="width:100%;" @onclick="Uitloggen">Uitloggen</button>
    }
</div>

@code {
    private bool Laden = true;
    private string? Fout;
    private string Naam = "Administrator";
    private string Initialen = "A";
    private string ClubNaam = "-";
    private string Email = "-";

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var gebruiker = ApiClient.AuthSession.Gebruiker ?? await ApiClient.GetCurrentUserAsync();
            if (gebruiker is not null)
            {
                Naam = $"{gebruiker.Voornaam} {gebruiker.Achternaam}".Trim();
                Email = gebruiker.Email;
                Initialen = BuildInitialen(Naam);
            }

            var club = await DataContext.GetEersteClubAsync();
            if (club is not null)
            {
                ClubNaam = club.Naam;
            }
        }
        catch (Exception ex)
        {
            Fout = $"Profiel kon niet geladen worden: {ex.Message}";
        }
        finally
        {
            Laden = false;
        }
    }

    private void Uitloggen()
    {
        ApiClient.Logout();
        Nav.NavigateTo("/login");
    }

    private static string BuildInitialen(string naam)
    {
        var delen = naam.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return string.Concat(delen.Take(2).Select(d => char.ToUpperInvariant(d[0])));
    }
}
